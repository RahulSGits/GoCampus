{
  "name": "gocampus",
  "version": "1.0.0",
  "description": "GoCampus Full Stack App Deployment",
  "scripts": {
    "start": "cd backend && npm start",
    "install-backend": "cd backend && npm install",
    "install-frontend": "cd frontend && npm install --include=dev",
    "build-frontend": "cd frontend && npm run build",
    "build": "npm run build-frontend",
    "heroku-postbuild": "npm run install-frontend && npm run build-frontend",
    "postinstall": "npm run install-backend && npm run install-frontend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  }
}
